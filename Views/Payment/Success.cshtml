@model Medicare.Models.Payment
@{
    ViewData["Title"] = "تم الدفع بنجاح";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5 text-center">

            <!-- Animated success icon -->
            <div class="mb-4">
                <div class="success-circle mx-auto d-flex align-items-center justify-content-center rounded-circle"
                     style="width:110px; height:110px; background: linear-gradient(135deg, #198754, #20c997); animation: popIn 0.5s ease;">
                    <i class="bi bi-check-lg text-white" style="font-size: 3.5rem;"></i>
                </div>
            </div>

            <h2 class="fw-bold text-success mb-1">تم الدفع بنجاح!</h2>
            <p class="text-muted fs-6 mb-4">تم استلام دفعتك وتأكيد موعدك الطبي</p>

            <!-- Receipt Card -->
            <div class="card border-0 shadow rounded-4 text-start mb-4">
                <div class="card-header bg-light border-0 py-3 rounded-top-4">
                    <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-receipt me-2"></i> إيصال الدفع</h6>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between border-bottom py-2">
                        <span class="text-muted">رقم المعاملة</span>
                        <span class="fw-bold text-primary font-monospace">@Model.TransactionId</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom py-2">
                        <span class="text-muted">المبلغ المسدد</span>
                        <span class="fw-bold text-success">@Model.Amount.ToString("F2") جنيه</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom py-2">
                        <span class="text-muted">طريقة الدفع</span>
                        <span class="fw-semibold">@Model.PaymentMethod</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom py-2">
                        <span class="text-muted">الطبيب</span>
                        <span class="fw-semibold">د. @Model.Appointment?.Doctor?.User?.FirstName @Model.Appointment?.Doctor?.User?.LastName</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom py-2">
                        <span class="text-muted">تاريخ الموعد</span>
                        <span class="fw-semibold">@Model.Appointment?.AppointmentDate.ToString("yyyy-MM-dd")</span>
                    </div>
                    <div class="d-flex justify-content-between py-2">
                        <span class="text-muted">تاريخ الدفع</span>
                        <span class="fw-semibold">@Model.PaymentDate.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                </div>
                <div class="card-footer bg-success bg-opacity-10 border-0 text-center rounded-bottom-4 py-3">
                    <span class="badge bg-success rounded-pill px-3 py-2 fs-6"><i class="bi bi-check-circle me-1"></i> مدفوع بالكامل</span>
                </div>
            </div>

            <div class="d-grid gap-2">
                <a asp-controller="Appointment" asp-action="MyAppointments" class="btn btn-primary rounded-pill py-2 fw-bold">
                    <i class="bi bi-calendar-check me-1"></i> عرض مواعيدي
                </a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill py-2">
                    <i class="bi bi-house me-1"></i> الرئيسية
                </a>
            </div>

        </div>
    </div>
</div>

<style>
    @@keyframes popIn {
        0%   { transform: scale(0.3); opacity: 0; }
        70%  { transform: scale(1.1); }
        100% { transform: scale(1); opacity: 1; }
    }
</style>
