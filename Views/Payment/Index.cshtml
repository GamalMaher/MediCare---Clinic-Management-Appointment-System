@model IEnumerable<Medicare.Models.Payment>
@{
    ViewData["Title"] = "سجل المدفوعات";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1"><i class="bi bi-journal-text me-2"></i> سجل المدفوعات</h2>
            <p class="text-muted mb-0">جميع المعاملات المالية في النظام</p>
        </div>
        <a asp-action="Dashboard" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-bar-chart-line me-1"></i> لوحة التحكم المالية
        </a>
    </div>

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-success fs-1 fw-bold">@Model.Count(p => p.Status == Medicare.Models.PaymentStatus.Completed)</div>
                <div class="text-muted small">مدفوعة</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-warning fs-1 fw-bold">@Model.Count(p => p.Status == Medicare.Models.PaymentStatus.Pending)</div>
                <div class="text-muted small">قيد الانتظار</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-danger fs-1 fw-bold">@Model.Count(p => p.Status == Medicare.Models.PaymentStatus.Failed)</div>
                <div class="text-muted small">فاشلة</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <div class="text-primary fs-4 fw-bold">@Model.Where(p => p.Status == Medicare.Models.PaymentStatus.Completed).Sum(p => p.Amount).ToString("F0")</div>
                <div class="text-muted small">إجمالي الإيرادات (جنيه)</div>
            </div>
        </div>
    </div>

    <!-- Transactions Table -->
    <div class="card border-0 shadow rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light text-secondary">
                        <tr>
                            <th>رقم المعاملة</th>
                            <th>المريض</th>
                            <th>الطبيب</th>
                            <th>المبلغ</th>
                            <th>طريقة الدفع</th>
                            <th>تاريخ الدفع</th>
                            <th>الحالة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-credit-card" style="font-size:3rem; color:#ccc;"></i>
                                    <h5 class="mt-3">لا توجد مدفوعات مسجلة حتى الآن</h5>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var p in Model)
                            {
                                <tr>
                                    <td><span class="font-monospace text-primary small">@p.TransactionId</span></td>
                                    <td>
                                        <span class="fw-semibold">@p.Appointment?.Patient?.User?.FirstName @p.Appointment?.Patient?.User?.LastName</span>
                                    </td>
                                    <td>
                                        <span>د. @p.Appointment?.Doctor?.User?.FirstName @p.Appointment?.Doctor?.User?.LastName</span>
                                    </td>
                                    <td>
                                        <span class="fw-bold text-success">@p.Amount.ToString("F2") <small class="text-muted">جنيه</small></span>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border rounded-pill px-3 py-1">@p.PaymentMethod</span>
                                    </td>
                                    <td>
                                        <span class="text-muted">@p.PaymentDate.ToString("yyyy-MM-dd HH:mm")</span>
                                    </td>
                                    <td>
                                        @switch (p.Status)
                                        {
                                            case Medicare.Models.PaymentStatus.Completed:
                                                <span class="badge bg-success rounded-pill px-3 py-2"><i class="bi bi-check-circle me-1"></i> مكتمل</span>
                                                break;
                                            case Medicare.Models.PaymentStatus.Pending:
                                                <span class="badge bg-warning text-dark rounded-pill px-3 py-2"><i class="bi bi-clock me-1"></i> انتظار</span>
                                                break;
                                            case Medicare.Models.PaymentStatus.Failed:
                                                <span class="badge bg-danger rounded-pill px-3 py-2"><i class="bi bi-x-circle me-1"></i> فاشل</span>
                                                break;
                                            case Medicare.Models.PaymentStatus.Refunded:
                                                <span class="badge bg-secondary rounded-pill px-3 py-2"><i class="bi bi-arrow-counterclockwise me-1"></i> مسترد</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
