@model Medicare.Models.Payment
@{
    ViewData["Title"] = "سداد رسوم الموعد";
}

<style>
    .payment-card { border-radius: 20px; overflow: hidden; }
    .payment-header { background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%); }
    .method-btn { border: 2px solid #e0e0e0; border-radius: 12px; padding: 12px; cursor: pointer; transition: all 0.2s; }
    .method-btn:hover, .method-btn.selected { border-color: #0d6efd; background: #f0f5ff; }
    .method-btn.selected .check-icon { display: inline-flex !important; }
    .check-icon { display: none !important; }
    .card-input { border: 1.5px solid #dee2e6; border-radius: 10px; font-size: 1rem; padding: 12px 16px; }
    .card-input:focus { border-color: #0d6efd; box-shadow: 0 0 0 0.2rem rgba(13,110,253,.15); }
</style>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 payment-card">
                <!-- Header -->
                <div class="payment-header text-white p-4 pb-5 text-center position-relative">
                    <h3 class="fw-bold mb-1"><i class="bi bi-credit-card-fill me-2"></i> سداد رسوم الكشف</h3>
                    <p class="opacity-75 mb-0 fs-6">إجراء آمن ومشفر لدفع رسوم الكشف الطبي</p>
                </div>

                <!-- Summary Card Overlap -->
                <div class="bg-white mx-3 rounded-3 shadow-sm p-3 mb-0" style="margin-top: -30px; position: relative; z-index: 2;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-0 small">الطبيب</p>
                            <h6 class="fw-bold mb-0">@ViewBag.DoctorName</h6>
                            <small class="text-secondary">@ViewBag.DoctorSpecialization</small>
                        </div>
                        <div class="text-center">
                            <p class="text-muted mb-0 small">الموعد</p>
                            <h6 class="fw-bold mb-0">@ViewBag.AppointmentDate</h6>
                            <small class="text-secondary">@ViewBag.AppointmentTime</small>
                        </div>
                        <div class="text-end">
                            <p class="text-muted mb-0 small">المبلغ المطلوب</p>
                            <h4 class="fw-bold text-primary mb-0">@Model.Amount.ToString("F0") <small class="fs-6">جنيه</small></h4>
                        </div>
                    </div>
                </div>

                <div class="card-body px-4 pt-4 pb-5">
                    <form asp-action="Pay" method="post" id="paymentForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="AppointmentId" />
                        <input type="hidden" asp-for="Amount" />
                        <input type="hidden" asp-for="Status" />

                        <!-- Payment Method Selection -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold text-secondary d-block mb-3"><i class="bi bi-wallet2 me-1"></i> اختر طريقة الدفع:</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <div class="method-btn selected text-center position-relative" onclick="selectMethod('بطاقة ائتمان', this)">
                                        <span class="check-icon position-absolute top-0 end-0 m-2 bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width:20px;height:20px;font-size:11px;">✓</span>
                                        <i class="bi bi-credit-card-2-front text-primary" style="font-size:1.8rem;"></i>
                                        <p class="mb-0 mt-1 fw-semibold small">Visa / MasterCard</p>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="method-btn text-center position-relative" onclick="selectMethod('فوري', this)">
                                        <span class="check-icon position-absolute top-0 end-0 m-2 bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width:20px;height:20px;font-size:11px;">✓</span>
                                        <i class="bi bi-cash-coin text-success" style="font-size:1.8rem;"></i>
                                        <p class="mb-0 mt-1 fw-semibold small">فوري / Fawry</p>
                                    </div>
                                </div>
                            </div>
                            <input type="hidden" asp-for="PaymentMethod" id="paymentMethodInput" value="بطاقة ائتمان" />
                        </div>

                        <!-- Card Details (shown for credit card) -->
                        <div id="cardDetails">
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-semibold">رقم البطاقة</label>
                                <input type="text" class="form-control card-input" placeholder="1234 5678 9012 3456" maxlength="19" id="cardNumber" oninput="formatCardNumber(this)" />
                            </div>
                            <div class="row g-3 mb-3">
                                <div class="col-6">
                                    <label class="form-label text-secondary small fw-semibold">تاريخ الانتهاء</label>
                                    <input type="text" class="form-control card-input" placeholder="MM / YY" maxlength="7" oninput="formatExpiry(this)" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label text-secondary small fw-semibold">رمز CVV</label>
                                    <input type="password" class="form-control card-input" placeholder="•••" maxlength="3" />
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label text-secondary small fw-semibold">الاسم على البطاقة</label>
                                <input type="text" class="form-control card-input" placeholder="Ahmed Mohamed" />
                            </div>
                        </div>

                        <!-- Fawry Details (hidden initially) -->
                        <div id="fawryDetails" class="d-none">
                            <div class="alert alert-info border-0 rounded-3 mb-4">
                                <i class="bi bi-info-circle me-2"></i>
                                سيتم إرسال رمز فوري على هاتفك. توجه لأي نقطة فوري وأذكر الرمز للكاشير لإتمام الدفع.
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold py-3" id="payBtn">
                                <i class="bi bi-shield-lock me-2"></i> ادفع الآن — @Model.Amount.ToString("F0") جنيه
                            </button>
                        </div>

                        <p class="text-center text-muted small mt-3 mb-0">
                            <i class="bi bi-lock-fill me-1 text-success"></i> مدفوعاتك مؤمنة ومشفرة بالكامل
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function selectMethod(method, el) {
            document.querySelectorAll('.method-btn').forEach(b => b.classList.remove('selected'));
            el.classList.add('selected');
            document.getElementById('paymentMethodInput').value = method;
            if (method === 'فوري') {
                document.getElementById('cardDetails').classList.add('d-none');
                document.getElementById('fawryDetails').classList.remove('d-none');
            } else {
                document.getElementById('cardDetails').classList.remove('d-none');
                document.getElementById('fawryDetails').classList.add('d-none');
            }
        }

        function formatCardNumber(input) {
            let v = input.value.replace(/\D/g, '').substring(0, 16);
            input.value = v.replace(/(.{4})/g, '$1 ').trim();
        }

        function formatExpiry(input) {
            let v = input.value.replace(/\D/g, '').substring(0, 4);
            if (v.length >= 2) v = v.substring(0, 2) + ' / ' + v.substring(2);
            input.value = v;
        }

        document.getElementById('paymentForm').addEventListener('submit', function(e) {
            var btn = document.getElementById('payBtn');
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> جاري معالجة الدفع...';
            btn.disabled = true;
        });
    </script>
}
