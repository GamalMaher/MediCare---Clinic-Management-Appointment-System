@model Medicare.Models.Appointment
@{
    ViewData["Title"] = "إلغاء الموعد";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-lg">
                <div class="card-header bg-danger text-white text-center py-4">
                    <h3 class="font-weight-light my-1 fw-bold">تأكيد إلغاء الحجز</h3>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="text-danger mb-4">
                        <i class="bi bi-calendar-x-fill" style="font-size: 4rem;"></i>
                    </div>

                    <h4 class="mb-3">هل أنت متأكد من رغبتك في إلغاء هذا الموعد؟</h4>
                    
                    <div class="alert alert-light text-start border shadow-sm p-3 mb-4">
                        <div class="row">
                            <div class="col-5 fw-bold text-secondary mb-1">الطبيب:</div>
                            <div class="col-7 mb-1">د. @Model.Doctor.User.FirstName @Model.Doctor.User.LastName</div>
                            
                            <div class="col-5 fw-bold text-secondary mb-1">التاريخ:</div>
                            <div class="col-7 mb-1">@Model.AppointmentDate.ToString("yyyy-MM-dd")</div>
                            
                            <div class="col-5 fw-bold text-secondary mb-1">الوقت:</div>
                            <div class="col-7 mb-1">@Model.StartTime.ToString(@"hh\:mm")</div>
                        </div>
                    </div>

                    <form asp-action="Cancel" method="post">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="d-flex justify-content-center gap-3">
                            <button type="submit" class="btn btn-danger btn-lg px-4 rounded-pill shadow-sm">تأكيد إلغاء الموعد</button>
                            <a asp-action="MyAppointments" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">إلغاء والتراجع</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
