@model IEnumerable<Medicare.Models.Appointment>
@{
    ViewData["Title"] = "مواعيدي الطبية";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold"><i class="bi bi-calendar-event me-2"></i> مواعيدي الطبية</h2>
        <a asp-controller="Doctor" asp-action="Index" class="btn btn-primary shadow-sm rounded-pill px-4">
            <i class="bi bi-search me-1"></i> احجز موعداً جديداً
        </a>
    </div>

    <div class="card shadow border-0 rounded-lg">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light text-secondary text-uppercase fs-7">
                        <tr>
                            <th scope="col">الطبيب</th>
                            <th scope="col">التخصص</th>
                            <th scope="col">التاريخ</th>
                            <th scope="col">الوقت</th>
                            <th scope="col">السبب</th>
                            <th scope="col">الحالة</th>
                            <th scope="col" class="text-center">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-calendar-x" style="font-size: 3rem; color: #ccc;"></i>
                                    <h5 class="my-3">ليس لديك أي مواعيد طبية محجوزة حالياً</h5>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px; font-weight: bold; font-size: 1rem;">
                                                @(item.Doctor.User.FirstName.Substring(0, 1) + item.Doctor.User.LastName.Substring(0, 1))
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fw-bold">د. @item.Doctor.User.FirstName @item.Doctor.User.LastName</h6>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border px-2 py-1 fs-7">
                                            @item.Doctor.Specialization.Name
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-secondary fw-semibold">@item.AppointmentDate.ToString("yyyy-MM-dd")</span>
                                    </td>
                                    <td>
                                        <span class="text-secondary">@item.StartTime.ToString(@"hh\:mm")</span>
                                    </td>
                                    <td>
                                        <span class="text-muted text-truncate d-inline-block" style="max-width: 150px;" title="@item.Reason">
                                            @(string.IsNullOrWhiteSpace(item.Reason) ? "فحص طبي" : item.Reason)
                                        </span>
                                    </td>
                                    <td>
                                        @switch (item.Status)
                                        {
                                            case Medicare.Models.AppointmentStatus.Pending:
                                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="bi bi-clock me-1"></i> قيد الانتظار</span>
                                                break;
                                            case Medicare.Models.AppointmentStatus.Confirmed:
                                                <span class="badge bg-primary px-3 py-2 rounded-pill"><i class="bi bi-check-circle me-1"></i> مؤكد</span>
                                                break;
                                            case Medicare.Models.AppointmentStatus.Completed:
                                                <span class="badge bg-success px-3 py-2 rounded-pill"><i class="bi bi-check-all me-1"></i> مكتمل</span>
                                                break;
                                            case Medicare.Models.AppointmentStatus.Cancelled:
                                                <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="bi bi-x-circle me-1"></i> ملغى</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2 flex-wrap">
                                            <a asp-controller="MedicalRecord" asp-action="PatientHistory" asp-route-patientId="@item.PatientId" class="btn btn-outline-info btn-sm px-3 rounded-pill"><i class="bi bi-file-earmark-medical"></i> سجلي الطبي</a>
                                            @if (item.Status == Medicare.Models.AppointmentStatus.Confirmed)
                                            {
                                                <a asp-controller="Payment" asp-action="Pay" asp-route-appointmentId="@item.Id" class="btn btn-success btn-sm px-3 rounded-pill"><i class="bi bi-credit-card me-1"></i>ادفع</a>
                                            }
                                            @if (item.Status == Medicare.Models.AppointmentStatus.Completed)
                                            {
                                                <a asp-controller="Review" asp-action="Create" asp-route-appointmentId="@item.Id" class="btn btn-outline-warning btn-sm px-3 rounded-pill"><i class="bi bi-star me-1"></i>قيّم</a>
                                            }
                                            @if (item.Status == Medicare.Models.AppointmentStatus.Pending || item.Status == Medicare.Models.AppointmentStatus.Confirmed)
                                            {
                                                <a asp-action="Cancel" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm px-3 rounded-pill">إلغاء الحجز</a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
