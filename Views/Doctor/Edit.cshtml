@model EditDoctorViewModel
@{
    ViewData["Title"] = "تعديل بيانات الطبيب";
    var specializations = ViewBag.Specializations as IEnumerable<Medicare.Models.Specialization>;
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-warning text-dark text-center py-4">
                    <h3 class="font-weight-light my-1 fw-bold">تعديل بيانات الطبيب</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="SpecializationId" class="form-label fw-bold">التخصص الطبي</label>
                            <select asp-for="SpecializationId" class="form-select">
                                <option value="">اختر التخصص...</option>
                                @if (specializations != null)
                                {
                                    @foreach (var spec in specializations)
                                    {
                                        <option value="@spec.Id">@spec.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="SpecializationId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConsultationFee" class="form-label fw-bold">سعر الكشف (بالجنيه)</label>
                            <input asp-for="ConsultationFee" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="ConsultationFee" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label fw-bold">رقم الهاتف للعيادة</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-warning btn-lg shadow-sm">حفظ التغييرات</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">إلغاء والعودة للقائمة</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
