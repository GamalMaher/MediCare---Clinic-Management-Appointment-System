@model CreateDoctorViewModel
@{
    ViewData["Title"] = "إضافة طبيب جديد";
    var specializations = ViewBag.Specializations as IEnumerable<Medicare.Models.Specialization>;
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-success text-white text-center py-4">
                    <h3 class="font-weight-light my-1">إضافة طبيب جديد إلى النظام</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- بيانات الحساب الأساسية -->
                        <h5 class="text-secondary mb-3 border-bottom pb-2">بيانات الحساب والاتصال</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FirstName" class="form-label fw-bold">الاسم الأول</label>
                                <input asp-for="FirstName" class="form-control" placeholder="أدخل الاسم الأول" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="LastName" class="form-label fw-bold">الاسم الأخير</label>
                                <input asp-for="LastName" class="form-control" placeholder="أدخل الاسم الأخير" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-bold">البريد الإلكتروني</label>
                                <input asp-for="Email" class="form-control" placeholder="name@medicare.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Password" class="form-label fw-bold">كلمة المرور المؤقتة</label>
                                <input asp-for="Password" class="form-control" type="password" placeholder="أدخل كلمة مرور قوية" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label fw-bold">رقم الهاتف للعيادة</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="مثال: 01xxxxxxxxx" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <!-- بيانات العمل الطبية -->
                        <h5 class="text-secondary mt-4 mb-3 border-bottom pb-2">التفاصيل المهنية والمالية</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="SpecializationId" class="form-label fw-bold">التخصص الطبي</label>
                                <select asp-for="SpecializationId" class="form-select">
                                    <option value="">اختر التخصص...</option>
                                    @if (specializations != null)
                                    {
                                        @foreach (var spec in specializations)
                                        {
                                            <option value="@spec.Id">@spec.Name</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="SpecializationId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ConsultationFee" class="form-label fw-bold">سعر الكشف (بالجنيه)</label>
                                <input asp-for="ConsultationFee" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                <span asp-validation-for="ConsultationFee" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LicenseNumber" class="form-label fw-bold">رقم الترخيص الطبي (License Number)</label>
                            <input asp-for="LicenseNumber" class="form-control" placeholder="أدخل رقم ترخيص وزارة الصحة" />
                            <span asp-validation-for="LicenseNumber" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">إضافة الطبيب للنظام</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">إلغاء والعودة للقائمة</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
