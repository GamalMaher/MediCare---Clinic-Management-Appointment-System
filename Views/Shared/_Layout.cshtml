<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Medicare</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Medicare.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-custom shadow-sm mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold text-success fs-3 me-2" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-heart-pulse-fill me-1"></i> Medicare
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-lg-center gap-1">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Doctor" asp-action="Index"><i class="bi bi-people-fill me-1"></i> إدارة الأطباء</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Patient" asp-action="Index"><i class="bi bi-person-heart me-1"></i> إدارة المرضى</a></li>
                            }
                            @if (User.IsInRole("Patient"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Doctor" asp-action="Index"><i class="bi bi-people-fill me-1"></i> احجز طبيباً</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Appointment" asp-action="MyAppointments"><i class="bi bi-calendar-event me-1"></i> جدول مواعيدي</a></li>
                            }
                            @if (User.IsInRole("Doctor"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Appointment" asp-action="DoctorAppointments"><i class="bi bi-calendar-check me-1"></i> تقويم مواعيدي</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="WorkingHours" asp-action="Index"><i class="bi bi-clock-history me-1"></i> أوقات تواجدي</a></li>
                            }
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Doctor" asp-action="Index"><i class="bi bi-people-fill me-1"></i> الأطباء المتوفرون</a></li>
                        }
                    </ul>
                    
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item text-secondary px-2">
                                <i class="bi bi-person-circle text-primary me-1"></i> مرحباً، @User.Identity.Name
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="med-btn med-btn-outline btn-sm text-danger py-1 px-3 border-danger"><i class="bi bi-box-arrow-right me-1"></i> خروج</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="med-btn med-btn-outline btn-sm px-3 py-1 text-primary border-primary" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-left me-1"></i> تسجيل الدخول</a></li>
                            <li class="nav-item"><a class="med-btn med-btn-primary btn-sm px-3 py-1 text-white" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus me-1"></i> حساب جديد</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- تذييل الصفحة الاحترافي بنكهة إنسانية ومريحة -->
    <footer class="med-footer text-center text-md-start">
        <div class="container">
            <div class="row text-end">
                <div class="col-md-6 mb-4 mb-md-0">
                    <h5 class="fw-bold text-success"><i class="bi bi-heart-pulse-fill me-1"></i> مستشفى Medicare</h5>
                    <p class="small text-muted">نحن هنا لتقديم أفضل رعاية صحية لخدمتك وحفظ سلامتك، بفضل تقنيات حجز المواعيد الحديثة وفريق طبي خبير ومتكامل.</p>
                </div>
                <div class="col-md-3 mb-4 mb-md-0">
                    <h5 class="fw-bold">روابط سريعة</h5>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="Index">الرئيسية</a></li>
                        <li><a asp-controller="Doctor" asp-action="Index">أطباؤنا</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h5 class="fw-bold">تواصل معنا</h5>
                    <p class="small text-muted mb-1"><i class="bi bi-geo-alt me-1 text-primary"></i> القاهرة، مصر</p>
                    <p class="small text-muted mb-1"><i class="bi bi-telephone me-1 text-primary"></i> 19999 (خط ساخن)</p>
                    <p class="small text-muted"><i class="bi bi-envelope me-1 text-primary"></i> support@medicare.com</p>
                </div>
            </div>
            <hr class="border-secondary my-4" />
            <div class="text-center small text-muted">
                &copy; @DateTime.Now.Year - Medicare. كل الحقوق محفوظة. تم تصميمه بكل حب لرعايتكم.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

